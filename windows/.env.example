# TradeBot Windows Execution Node

TRADEBOT_NODE_NAME=windows-node-vantage-mt5
TRADEBOT_NODE_BROKER=vantage

# Use "stub" until ready.
# Change to "mt5" only after MT5 terminal is installed and logged in.
TRADEBOT_NODE_PLATFORM=mt5

TRADEBOT_NODE_HOST=0.0.0.0
TRADEBOT_NODE_PORT=8008

# MT5 settings
TRADEBOT_MT5_TERMINAL_PATH=C:\Trading\Vantage_MT5\terminal64.exe
TRADEBOT_MT5_DEVIATION=20

# Safety gate.
# Set to true to enable live/demo MT5 order execution.
# The MT5 terminal must be running and logged in before enabling this.
TRADEBOT_LIVE_TRADING_ENABLED=true